<odoo>
    <!-- Tree view -->
    <record id="view_advance_amount_tree" model="ir.ui.view">
        <field name="name">advance.amount.tree</field>
        <field name="model">advance.amount</field>
        <field name="arch" type="xml">
            <tree string="Advance Amounts">
                <field name="date"/>
                <field name="reference_no" string="UHID"/>
                <field name="name"/>
                <field name="advance_in_amount"/>

                <!--                <field name="admission_id"/>-->
            </tree>
        </field>
    </record>

    <!-- Form view -->
    <record id="view_advance_amount_form" model="ir.ui.view">
        <field name="name">advance.amount.form</field>
        <field name="model">advance.amount</field>
        <field name="arch" type="xml">
            <form string="Advance Amount">
                <header> <button name="action_print_advance_amount"
                            string="Print"
                            type="object"
                            class="btn-primary" invisible="1"/></header>
                <sheet>
                    <group col="4">
                        <group>
                            <field name="date"/>
                        </group>
                        <group>
                            <field name="reference_no" string="UHID" options="{'no_create': True, 'no_edit': True,}"/>
                        </group>
                        <group>
                            <field name="name"/>
                        </group>
                        <group>
                            <field name="pay_mode"/>

                        </group>
                        <group>
                            <field name="advance_in_amount"/>

                        </group>

                        <!--                        <field name="admission_id"/>-->
                    </group>
                </sheet>
            </form>
        </field>
    </record>
    <record id="action_advance_amount" model="ir.actions.act_window">
        <field name="name">Advance Amounts</field>
        <field name="res_model">advance.amount</field>
        <field name="view_mode">tree,form</field>
    </record>


    <menuitem id="menu_my_patient_template_root" name="Patient Registration" parent="menu_homeo_head" sequence="2"/>

   <!-- Paper Format -->
<record id="paperformat_advance_challan" model="report.paperformat">
    <field name="name">Advance Challan Format</field>
    <field name="default" eval="False"/>
    <field name="format">A4</field>
    <field name="orientation">Landscape</field>
    <field name="margin_top">10</field>
    <field name="margin_bottom">10</field>
    <field name="margin_left">7</field>
    <field name="margin_right">7</field>
    <field name="header_line" eval="False"/>
</record>

<!-- Menu Item -->
<menuitem id="menu_advance_amount"
          name="Advance Amounts"
          parent="menu_my_patient_template_root"
          action="action_advance_amount"
          sequence="10"/>

<!-- Report Action -->
<record id="action_report_advance_challan" model="ir.actions.report">
    <field name="name">Advance Challan</field>
    <field name="model">advance.amount</field>
    <field name="report_type">qweb-pdf</field>
    <field name="report_name">homeo_doctor.report_advance_amount</field>
    <field name="report_file">homeo_doctor.report_advance_amount</field>
    <field name="binding_model_id" ref="model_advance_amount"/>
    <field name="binding_type">report</field>
    <field name="paperformat_id" ref="homeo_doctor.paperformat_advance_challan"/>
</record>


